                "embedding_params": null,
                "cache_ttl": null,
                "dataset_query": {
                    "lib/type": "mbql/query",
                    "database": 2,
                    "stages": [
                        {
                            "lib/type": "mbql.stage/native",
                            "native": "SELECT ano_mes,\n    ROUND(AVG(rentabilidade_mes_pct)::numeric, 4) AS rent_media_mercado,\n    ROUND(MAX(taxa_anual_bcb / 12)::numeric, 4)   AS selic_mensal\nFROM gold_cvm.fundo_mensal\nWHERE meses_com_dados >= 6\n  AND rentabilidade_mes_pct BETWEEN -100 AND 500 AND taxa_anual_bcb IS NOT NULL\nGROUP BY ano_mes ORDER BY ano_mes"
                        }
                    ]
                },
