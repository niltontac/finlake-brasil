                    "lib/type": "mbql/query",
                    "database": 2,
                    "stages": [
                        {
                            "lib/type": "mbql.stage/native",
                            "native": "SELECT cnpj_fundo, COALESCE(gestor, 'N\u00e3o informado') AS gestor,\n    ano_mes, ROUND(rentabilidade_mes_pct::numeric, 4) AS rentabilidade_mes_pct\nFROM gold_cvm.fundo_mensal\nWHERE meses_com_dados >= 6 AND rentabilidade_mes_pct BETWEEN -100 AND 500\nORDER BY rentabilidade_mes_pct DESC LIMIT 10"
                        }
                    ]
                },
