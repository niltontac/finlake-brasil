                    "lib/type": "mbql/query",
                    "database": 2,
                    "stages": [
                        {
                            "lib/type": "mbql.stage/native",
                            "native": "SELECT COALESCE(gestor, 'N\u00e3o informado') AS gestor,\n    COUNT(DISTINCT cnpj_fundo) AS qtd_fundos,\n    ROUND(AVG(alpha_selic)::numeric, 4) AS alpha_selic_medio,\n    ROUND(AVG(vl_patrim_liq_medio)::numeric, 0) AS pl_medio\nFROM gold_cvm.fundo_mensal\nWHERE meses_com_dados >= 6 AND alpha_selic IS NOT NULL AND gestor IS NOT NULL\nGROUP BY gestor HAVING COUNT(DISTINCT cnpj_fundo) >= 2\nORDER BY alpha_selic_medio DESC LIMIT 10"
                        }
                    ]
                },
